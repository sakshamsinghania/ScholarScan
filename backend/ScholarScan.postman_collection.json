	"item": [
		{
			"name": "Health",
			"description": "Health check endpoints to verify system status, component availability, and capability flags.",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/health",
							"host": ["{{baseUrl}}"],
							"path": ["api", "health"]
						},
						"description": "Returns the current health status of all system components including OCR, NLP models, Groq-backed LLM configuration, and PDF support. Use this to verify the backend is running and which capabilities are available before submitting assessments. For auto-reference generation, confirm `llm_configured` is `true`."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('Required health fields exist', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('status');",
									"    pm.expect(json).to.have.property('ocr_available');",
									"    pm.expect(json).to.have.property('tesseract_available');",
									"    pm.expect(json).to.have.property('vision_credentials_configured');",
									"    pm.expect(json).to.have.property('sbert_loaded');",
									"    pm.expect(json).to.have.property('spacy_model_loaded');",
									"    pm.expect(json).to.have.property('llm_configured');",
									"    pm.expect(json).to.have.property('pdf_support');",
									"    pm.expect(json).to.have.property('capabilities');",
									"    pm.expect(json).to.have.property('supported_modes');",
									"    pm.expect(json).to.have.property('timestamp');",
									"});",
									"",
									"pm.test('Status is healthy or degraded', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.status).to.be.oneOf(['healthy', 'degraded']);",
									"});",
									"",
									"pm.test('Capabilities object has expected keys', function () {",
									"    var caps = pm.response.json().capabilities;",
									"    pm.expect(caps).to.have.property('ocr');",
									"    pm.expect(caps).to.have.property('semantic_similarity');",
									"    pm.expect(caps).to.have.property('llm');",
									"    pm.expect(caps).to.have.property('pdf');",
									"});",
									"",
									"pm.test('Supported modes object has expected keys', function () {",
									"    var modes = pm.response.json().supported_modes;",
									"    pm.expect(modes).to.have.property('manual_assessment');",
									"    pm.expect(modes).to.have.property('auto_reference_generation');",
									"    pm.expect(modes).to.have.property('multi_question_assessment');",
									"});"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Health Check With Origin Header",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Origin",
								"value": "{{originHeader}}",
								"description": "Simulates a cross-origin request from the frontend dev server"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/health",
							"host": ["{{baseUrl}}"],
							"path": ["api", "health"]
						},
						"description": "Health check with an Origin header to verify CORS configuration. Simulates a request from the frontend application at the configured origin. Useful for debugging CORS issues during local development."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('Required fields exist', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('status');",
									"    pm.expect(json.status).to.be.oneOf(['healthy', 'degraded']);",
									"});"
								]
							}
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "Assessment",
			"description": "Assessment submission endpoints. Supports two modes:\n\n**Manual (synchronous):** Upload an image with a model answer for immediate single-question grading (HTTP 200).\n\n**Async (background):** Upload an image or PDF answer file (optionally with a question paper) for multi-question processing (HTTP 202). Groq is used for automatic reference-answer generation when manual model answers are not supplied. The response includes a `task_id` to track progress and retrieve results.\n\n### Async Assessment Flow\n1. Submit via `POST /api/assess` \u2192 receive `task_id`\n2. Stream progress via `GET /api/progress/stream/{task_id}`\n3. Fetch result via `GET /api/task/{task_id}/result`",
			"item": [
				{
					"name": "Manual Assessment - Image + Model Answer",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "image",
									"type": "file",
									"src": "{{manualImagePath}}",
									"description": "Image of the student's handwritten or printed answer (jpg, jpeg, png)"
								},
								{
									"key": "model_answer",
									"value": "{{modelAnswer}}",
									"type": "text",
									"description": "The reference/model answer to compare against"
								},
								{
									"key": "question_id",
									"value": "{{questionId}}",
									"type": "text",
									"description": "Identifier for the question being assessed"
								},
								{
									"key": "student_id",
									"value": "{{studentId}}",
									"type": "text",
									"description": "Identifier for the student"
								},
								{
									"key": "max_marks",
									"value": "{{maxMarks}}",
									"type": "text",
									"description": "Maximum marks for this question (integer, 1\u2013100)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/assess",
							"host": ["{{baseUrl}}"],
							"path": ["api", "assess"]
						},
						"description": "Synchronous single-question assessment. Uploads an image of a student answer along with a model answer. The server performs OCR, text cleaning, similarity scoring, and grading, then returns the complete result immediately.\n\nRequires: `image` (file) and `model_answer` (text).\nOptional: `question_id`, `student_id`, `max_marks`.\n\nNote: When `model_answer` is provided, only image uploads are supported (not PDFs). Do not include `question_file` in manual mode."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('Required assessment result fields exist', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('extracted_text');",
									"    pm.expect(json).to.have.property('cleaned_text');",
									"    pm.expect(json).to.have.property('tfidf_score');",
									"    pm.expect(json).to.have.property('sbert_score');",
									"    pm.expect(json).to.have.property('similarity_score');",
									"    pm.expect(json).to.have.property('keyword_overlap');",
									"    pm.expect(json).to.have.property('missing_keywords');",
									"    pm.expect(json).to.have.property('marks');",
									"    pm.expect(json).to.have.property('max_marks');",
									"    pm.expect(json).to.have.property('grade');",
									"    pm.expect(json).to.have.property('feedback');",
									"    pm.expect(json).to.have.property('assessed_at');",
									"});",
									"",
									"pm.test('Score fields are numbers', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json.tfidf_score).to.be.a('number');",
									"    pm.expect(json.sbert_score).to.be.a('number');",
									"    pm.expect(json.similarity_score).to.be.a('number');",
									"    pm.expect(json.marks).to.be.a('number');",
									"    pm.expect(json.max_marks).to.be.a('number');",
									"});"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Async Assessment - Image Without Model Answer",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "image",
									"type": "file",
									"src": "{{manualImagePath}}",
									"description": "Image of the student's answer"
								},
								{
									"key": "student_id",
									"value": "{{studentId}}",
									"type": "text",
									"description": "Identifier for the student"
								},
								{
									"key": "max_marks",
									"value": "{{maxMarks}}",
									"type": "text",
									"description": "Maximum marks (integer, 1\u2013100)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/assess",
							"host": ["{{baseUrl}}"],
							"path": ["api", "assess"]
						},
						"description": "Async assessment triggered by submitting an image without a model answer. The server queues the assessment for background processing and returns a `task_id` (HTTP 202). Use this task_id to stream progress or fetch the final result.\n\nThe backend will attempt Groq-powered auto-reference generation, so `GET /api/health` should report `llm_configured: true` before using this mode."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 202', function () {",
									"    pm.response.to.have.status(202);",
									"});",
									"",
									"pm.test('Response is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('Task ID exists and status is processing', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('task_id');",
									"    pm.expect(json.task_id).to.be.a('string').and.not.empty;",
									"    pm.expect(json.status).to.eql('processing');",
									"});",
									"",
									"pm.test('Save task_id to collection variable', function () {",
									"    var json = pm.response.json();",
									"    if (json.task_id) {",
									"        pm.collectionVariables.set('taskId', json.task_id);",
									"    }",
									"});"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Async Assessment - PDF Answer File",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "answer_file",
									"type": "file",
									"src": "{{answerFilePath}}",
									"description": "PDF file containing the student's answers"
								},
								{
									"key": "student_id",
									"value": "{{studentId}}",
									"type": "text",
									"description": "Identifier for the student"
								},
								{
									"key": "max_marks",
									"value": "{{maxMarks}}",
									"type": "text",
									"description": "Maximum marks per question (integer, 1\u2013100)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/assess",
							"host": ["{{baseUrl}}"],
							"path": ["api", "assess"]
						},
						"description": "Async multi-question assessment using a PDF answer file. The server extracts text from the PDF, splits it into individual answers, and processes each question in the background.\n\nIf authoritative question text can be resolved, the backend uses Groq to generate reference answers before scoring. Returns HTTP 202 with a `task_id`. Use the Progress and Results endpoints to monitor and retrieve the outcome."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 202', function () {",
									"    pm.response.to.have.status(202);",
									"});",
									"",
									"pm.test('Response is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('Task ID exists and status is processing', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('task_id');",
									"    pm.expect(json.task_id).to.be.a('string').and.not.empty;",
									"    pm.expect(json.status).to.eql('processing');",
									"});",
									"",
									"pm.test('Save task_id to collection variable', function () {",
									"    var json = pm.response.json();",
									"    if (json.task_id) {",
									"        pm.collectionVariables.set('taskId', json.task_id);",
									"    }",
									"});"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Async Assessment - PDF Answer File + Question Paper",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "answer_file",
									"type": "file",
									"src": "{{answerFilePath}}",
									"description": "PDF file containing the student's answers"
								},
								{
									"key": "question_file",
									"type": "file",
									"src": "{{questionFilePath}}",
									"description": "PDF file containing the question paper (used to extract questions and generate model answers)"
								},
								{
									"key": "student_id",
									"value": "{{studentId}}",
									"type": "text",
									"description": "Identifier for the student"
								},
								{
									"key": "max_marks",
									"value": "{{maxMarks}}",
									"type": "text",
									"description": "Maximum marks per question (integer, 1\u2013100)"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/assess",
							"host": ["{{baseUrl}}"],
							"path": ["api", "assess"]
						},
						"description": "Async assessment with both an answer file and a question paper. The server extracts questions from the question paper, generates model answers using the configured Groq/OpenAI-compatible LLM, then assesses each student answer against the generated reference.\n\nThis is the most comprehensive assessment mode. Returns HTTP 202 with a `task_id`."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 202', function () {",
									"    pm.response.to.have.status(202);",
									"});",
									"",
									"pm.test('Response is JSON', function () {",
									"    pm.response.to.be.json;",
									"});",
									"",
									"pm.test('Task ID exists and status is processing', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('task_id');",
									"    pm.expect(json.task_id).to.be.a('string').and.not.empty;",
									"    pm.expect(json.status).to.eql('processing');",
									"});",
									"",
									"pm.test('Save task_id to collection variable', function () {",
									"    var json = pm.response.json();",
									"    if (json.task_id) {",
									"        pm.collectionVariables.set('taskId', json.task_id);",
									"    }",
									"});"
								]
							}
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "Progress",
			"description": "Server-Sent Events (SSE) endpoints for streaming real-time progress updates during async assessment tasks.\n\n**Important:** Postman does not natively support SSE like a browser's `EventSource` API. These requests are included for debugging and inspecting the raw streamed output. For full SSE consumption, use a browser, `curl`, or a dedicated SSE client.\n\nEvent payloads may include: `stage`, `status`, `message`, `step`, `total_steps`.",
			"item": [
				{
					"name": "Stream Progress By Task ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "text/event-stream",
								"description": "Request SSE content type"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/progress/stream/{{taskId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "progress", "stream", "{{taskId}}"]
						},
						"description": "Streams real-time progress events for an async assessment task via Server-Sent Events (SSE).\n\n**Note:** Postman may not fully render SSE streams like a browser EventSource client. The response body will show raw SSE data lines (`data: {...}`). This request is included for debugging and inspecting the streamed output.\n\nEvent payloads may include:\n- `stage`: current processing stage\n- `status`: event status\n- `message`: human-readable progress message\n- `step` / `total_steps`: numeric progress indicators\n\nRequires a valid `taskId` from a prior async assessment submission."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Content-Type includes text/event-stream', function () {",
									"    var contentType = pm.response.headers.get('Content-Type');",
									"    pm.expect(contentType).to.include('text/event-stream');",
									"});"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "Stream Progress - Unknown Task",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "text/event-stream",
								"description": "Request SSE content type"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/progress/stream/nonexistent-task-id-12345",
							"host": ["{{baseUrl}}"],
							"path": ["api", "progress", "stream", "nonexistent-task-id-12345"]
						},
						"description": "Attempts to stream progress for a task ID that does not exist. Expected to return HTTP 404."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 404', function () {",
									"    pm.response.to.have.status(404);",
									"});"
								]
							}
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "Results",
			"description": "Endpoints for retrieving assessment results. Includes both individual task results and historical result browsing with optional filtering.\n\n### Task Result States\n- **200**: Result ready, full assessment data returned\n- **202**: Task still processing\n- **404**: Task not found\n\n### Multi-Question Result Status\n- `completed`: every detected question was graded successfully\n- `partial_failure`: one or more questions could not be graded automatically; inspect per-question `status` and `failure_reason`\n\n### History Result Types\n- `single_question`: Individual question assessment with score, grade, and feedback\n- `multi_question`: Multi-question assessment with aggregate scores and per-question breakdown",
			"item": [
				{
					"name": "Get Task Result",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/task/{{taskId}}/result",
							"host": ["{{baseUrl}}"],
							"path": ["api", "task", "{{taskId}}", "result"]
						},
						"description": "Fetches the final result for an async assessment task. Returns HTTP 200 with the complete result when processing is finished, HTTP 202 if still processing, or HTTP 404 if the task does not exist.\n\nFor multi-question assessments, the response includes `total_score`, `max_total_score`, `total_questions`, `failed_questions`, aggregate `status`, and a `results` array with per-question details. Each per-question entry now includes `status` (`completed` or `failed`), and failed entries may include `failure_reason` instead of a real grade outcome.\n\nRequires a valid `taskId` from a prior async assessment submission."
					},
					"event": [
						{
